@inherits LayoutComponentBase
@inject QuestionService QuestionService
@inject NavigationManager Navigation

<div class="page">
    <div class="sidebar">
        <div class="sidebar-header">
            <h1>🎯 Cert Study Editor</h1>
        </div>
        
        <div class="sidebar-content">
            <div class="nav-section">
                <h3>Menu</h3>
                <div class="nav-item @(IsActive(""))" @onclick="() => Navigate("")">
                    <span class="icon">📊</span>
                    <span>Dashboard</span>
                </div>
                <div class="nav-item @(IsActive("search"))" @onclick="() => Navigate("search")">
                    <span class="icon">🔍</span>
                    <span>Search</span>
                </div>
            </div>
            
            <div class="nav-section">
                <h3>Certifications</h3>
                @foreach (var cert in certifications)
                {
                    <div class="nav-item @(IsActive($"cert/{cert.Id}"))" 
                         @onclick="() => Navigate($"cert/{cert.Id}")">
                        <span class="icon">📝</span>
                        <span>@cert.Code</span>
                    </div>
                }
            </div>
            
            <div class="nav-section">
                <h3>Actions</h3>
                <div class="nav-item" @onclick="ExportAll">
                    <span class="icon">📥</span>
                    <span>Export All</span>
                </div>
            </div>
        </div>
    </div>

    <main class="main-content">
        @Body
    </main>
</div>

@code {
    private List<Certification> certifications = new();

    protected override async Task OnInitializedAsync()
    {
        certifications = await QuestionService.GetCertificationsAsync();
        Navigation.LocationChanged += (_, _) => StateHasChanged();
    }

    private void Navigate(string path) => Navigation.NavigateTo(path);
    private bool IsActive(string path) => Navigation.ToBaseRelativePath(Navigation.Uri) == path;

    private async Task ExportAll()
    {
        // Export logic
    }
}
