@page "/question/{QuestionId:int}"
@page "/question/new/{CertId}"
@inject QuestionService QuestionService
@inject QuestionCommandService CommandService
@inject NavigationManager Navigation
@inject OllamaValidationService OllamaService
@implements IDisposable

@if (question != null)
{
    <div class="toolbar">
        <h2>@(isNew ? "New Question" : $"Edit Q{question.Number}")</h2>
        <div class="toolbar-actions">
            <button class="btn btn-primary" @onclick="Save">💾 Save</button>
            <button class="btn btn-secondary" @onclick="Back">← Back</button>
            @if (!isNew)
            {
                <button class="btn btn-secondary" @onclick="Validate" disabled="@isValidating">
                    @(isValidating ? "⏳" : "✓") Validate
                </button>
            }
        </div>
    </div>

    <DomainSelector Domains="@domains" @bind-SelectedDomainId="question.DomainId" />

    <div class="form-group">
        <label>Type</label>
        <select @bind="question.Type">
            <option value="@QuestionType.Single">Single Answer</option>
            <option value="@QuestionType.Multi">Multi-Select</option>
            <option value="@QuestionType.Ordering">Ordering</option>
        </select>
    </div>

    <div class="form-group">
        <label>Question Stem</label>
        <textarea @bind="question.Stem" @bind:event="oninput" @oninput="OnChange" rows="4" />
    </div>

    <AnswerEditor Question="@question" OnChange="OnChange" />

    <div class="form-group">
        <label>Explanation</label>
        <textarea @bind="question.Explanation" @bind:event="oninput" @oninput="OnChange" rows="6" />
    </div>

    @if (saveStatus != null)
    {
        <div class="save-status @saveStatusClass">@saveStatus</div>
    }

    @if (validationResult != null)
    {
        <ValidationResultCard Result="@validationResult" />
    }
}

@code {
    [Parameter] public int? QuestionId { get; set; }
    [Parameter] public string? CertId { get; set; }

    private Question? question;
    private List<Domain> domains = new();
    private bool isNew => QuestionId == null;
    private bool isValidating = false;
    private ValidationResult? validationResult;
    private string? saveStatus;
    private string? saveStatusClass;

    private AutoSaveTimer? autoSave;

    protected override async Task OnInitializedAsync()
    {
        autoSave = new AutoSaveTimer(2000);
        autoSave.OnChangeAsync(AutoSaveAsync);

        if (QuestionId.HasValue)
        {
            question = await QuestionService.GetQuestionAsync(QuestionId.Value);
            domains = new List<Domain> { question!.Domain };
        }
        else if (CertId != null)
        {
            var cert = await QuestionService.GetCertificationAsync(CertId);
            domains = cert?.Domains.ToList() ?? new();
            question = await CommandService.CreateAsync(CertId, domains.First().Id);
        }
    }

    private void OnChange() => autoSave?.OnChangeAsync(AutoSaveAsync);

    private async Task AutoSaveAsync()
    {
        if (question == null) return;
        await CommandService.SaveAsync(question);
        saveStatus = "Auto-saved";
        saveStatusClass = "auto";
        StateHasChanged();
    }

    private async Task Save()
    {
        if (question == null) return;

        var validation = QuestionValidator.Validate(question);
        if (!validation.IsValid)
        {
            saveStatus = string.Join(", ", validation.Errors);
            saveStatusClass = "error";
            return;
        }

        autoSave?.ForceSave();
        await CommandService.SaveAsync(question);
        saveStatus = "Saved!";
        saveStatusClass = "success";
        await Task.Delay(1000);
        Navigation.NavigateTo($"cert/{question.CertificationId}");
    }

    private void Back() => Navigation.NavigateTo(question != null ? $"cert/{question.CertificationId}" : "/");

    private async Task Validate()
    {
        if (question == null) return;
        isValidating = true;
        validationResult = await OllamaService.ValidateAsync(question);
        isValidating = false;
    }

    public void Dispose() => autoSave?.Dispose();
}
