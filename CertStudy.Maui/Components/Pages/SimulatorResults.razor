@inject ScoreCalculator Calculator

<div class="simulator-results">
    <div class="result-header">
        <h2>Exam Complete</h2>
        @if (Attempt?.IsPassed == true)
        {
            <div class="pass-badge">✓ PASSED</div>
        }
        else
        {
            <div class="fail-badge">✗ FAILED</div>
        }
    </div>

    <div class="score-display">
        <div class="score-circle @(Attempt?.IsPassed == true ? "pass" : "fail")">
            <div class="score-value">@Attempt?.ScorePercent.ToString("F1")%</div>
            <div class="score-label">Score</div>
        </div>
        <div class="score-details">
            <p>Correct: <strong>@Attempt?.CorrectCount / @Attempt?.TotalQuestions</strong></p>
            <p>Answered: <strong>@Attempt?.AnsweredCount / @Attempt?.TotalQuestions</strong></p>
            <p>Time: <strong>@FormatTime(Attempt?.TimeSpentSeconds ?? 0)</strong></p>
            <p>Passing: <strong>75%</strong></p>
        </div>
    </div>

    @if (Attempt?.IsPassed == false && Attempt?.Answers.Any(a => !a.IsAnswered) == true)
    {
        <div class="unanswered-warning">
            ⚠️ You had @Attempt.Answers.Count(a => !a.IsAnswered) unanswered questions
        </div>
    }

    <div class="results-actions">
        <button class="btn" @onclick="OnReview">Review Answers</button>
        <button class="btn btn-primary" @onclick="OnRetry">Try Again</button>
        <button class="btn btn-secondary" @onclick="OnExit">Exit</button>
    </div>
</div>

@code {
    [Parameter] public ExamAttempt? Attempt { get; set; }
    [Parameter] public EventCallback OnRetry { get; set; }
    [Parameter] public EventCallback OnExit { get; set; }
    [Parameter] public EventCallback OnReview { get; set; }

    private string FormatTime(int seconds)
    {
        var m = seconds / 60;
        var s = seconds % 60;
        return $"{m:D2}:{s:D2}";
    }
}
