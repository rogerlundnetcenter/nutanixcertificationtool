<div class="simulator-header @(Timer?.IsWarning == true ? "warning" : "")">
    <div class="timer">
        ⏱️ @Timer?.FormatTime()
    </div>
    <div class="progress">
        Answered: @Answered / @Total
    </div>
    <div class="actions">
        <button class="btn btn-sm" @onclick="OnSubmit">Submit Early</button>
    </div>
</div>

@code {
    [Parameter] public ExamTimer? Timer { get; set; }
    [Parameter] public int Current { get; set; }
    [Parameter] public int Total { get; set; }
    [Parameter] public int? Answered { get; set; }
    [Parameter] public EventCallback OnPause { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }
}
