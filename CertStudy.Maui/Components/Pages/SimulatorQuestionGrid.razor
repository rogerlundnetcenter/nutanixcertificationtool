<div class="question-grid">
    @if (Questions != null)
    {
        @for (int i = 0; i < Questions.Count; i++)
        {
            var q = Questions[i];
            var idx = i;
            <div class="grid-cell @(GetCellClass(q, i))" @onclick="() => OnNavigate.InvokeAsync(idx)">
                @(i + 1)
            </div>
        }
    }
</div>

@code {
    [Parameter] public List<ExamAnswer>? Questions { get; set; }
    [Parameter] public int CurrentIndex { get; set; }
    [Parameter] public EventCallback<int> OnNavigate { get; set; }

    private string GetCellClass(ExamAnswer answer, int index)
    {
        var classes = new List<string>();
        if (index == CurrentIndex) classes.Add("current");
        if (answer.IsAnswered) classes.Add("answered");
        return string.Join(" ", classes);
    }
}
