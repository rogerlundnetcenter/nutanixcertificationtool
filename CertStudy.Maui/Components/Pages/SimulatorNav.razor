<div class="simulator-nav">
    <div class="nav-section">
        @if (HasPrevious)
        {
            <button class="btn" @onclick="OnPrevious">← Previous</button>
        }
    </div>

    <div class="nav-center">
        <span class="question-counter">@CurrentIndex / @Total</span>
    </div>

    <div class="nav-section">
        @if (!IsLast)
        {
            <button class="btn btn-primary" @onclick="OnNext">Next →</button>
        }
        else
        {
            <button class="btn btn-success" @onclick="OnFinish">Finish Exam ✓</button>
        }
    </div>
</div>

@code {
    [Parameter] public bool HasPrevious { get; set; }
    [Parameter] public bool HasNext { get; set; }
    [Parameter] public bool IsLast { get; set; }
    [Parameter] public int CurrentIndex { get; set; }
    [Parameter] public int Total { get; set; }
    [Parameter] public EventCallback OnPrevious { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnFinish { get; set; }
}
