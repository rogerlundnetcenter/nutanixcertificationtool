<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CertStudy.Avalonia.Views.OptionCard"
             x:Name="Root"
             Cursor="Hand">

  <UserControl.Styles>
    <!-- Base option card panel style -->
    <Style Selector="Border.optionCardBorder">
      <Setter Property="Background" Value="#16172A"/>
      <Setter Property="BorderBrush" Value="#2A2B45"/>
      <Setter Property="BorderThickness" Value="1.5"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>

    <!-- Hover state (not selected, not submitted) -->
    <Style Selector="Border.optionCardBorder:pointerover">
      <Setter Property="Background" Value="#1E1F38"/>
      <Setter Property="BorderBrush" Value="#444466"/>
      <Setter Property="BoxShadow" Value="0 0 8 0 #00F0FF20"/>
    </Style>

    <!-- Selected state -->
    <Style Selector="Border.optionCardBorder.selected">
      <Setter Property="BorderBrush" Value="#00F0FF"/>
      <Setter Property="Background" Value="#1A2B3A"/>
      <Setter Property="BoxShadow" Value="0 0 12 0 #00F0FF40"/>
    </Style>

    <!-- Correct state (after submit) -->
    <Style Selector="Border.optionCardBorder.correct">
      <Setter Property="BorderBrush" Value="#00E676"/>
      <Setter Property="Background" Value="#1A3328"/>
      <Setter Property="BoxShadow" Value="0 0 12 0 #00E67640"/>
    </Style>

    <!-- Wrong state (after submit) -->
    <Style Selector="Border.optionCardBorder.wrong">
      <Setter Property="BorderBrush" Value="#FF5252"/>
      <Setter Property="Background" Value="#331A1A"/>
      <Setter Property="BoxShadow" Value="0 0 12 0 #FF525240"/>
    </Style>

    <!-- Letter circle base -->
    <Style Selector="Border.letterCircle">
      <Setter Property="Background" Value="#252642"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#3A3B55"/>
      <Setter Property="CornerRadius" Value="24"/>
      <Setter Property="Width" Value="40"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Letter circle selected -->
    <Style Selector="Border.letterCircle.selected">
      <Setter Property="Background" Value="#00F0FF"/>
      <Setter Property="BorderBrush" Value="#00F0FF"/>
    </Style>

    <!-- Letter circle correct -->
    <Style Selector="Border.letterCircle.correct">
      <Setter Property="Background" Value="#00E676"/>
      <Setter Property="BorderBrush" Value="#00E676"/>
    </Style>

    <!-- Letter circle wrong -->
    <Style Selector="Border.letterCircle.wrong">
      <Setter Property="Background" Value="#FF5252"/>
      <Setter Property="BorderBrush" Value="#FF5252"/>
    </Style>

    <!-- Letter text base -->
    <Style Selector="TextBlock.letterText">
      <Setter Property="Foreground" Value="#8888AA"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Letter text when circle is highlighted -->
    <Style Selector="TextBlock.letterText.selected">
      <Setter Property="Foreground" Value="#0B0B1A"/>
    </Style>

    <Style Selector="TextBlock.letterText.correct">
      <Setter Property="Foreground" Value="#0B0B1A"/>
    </Style>

    <Style Selector="TextBlock.letterText.wrong">
      <Setter Property="Foreground" Value="#0B0B1A"/>
    </Style>

    <!-- Option text -->
    <Style Selector="TextBlock.optionText">
      <Setter Property="Foreground" Value="#D0D0E6"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.optionText.selected">
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- Checkmark -->
    <Style Selector="TextBlock.checkmark">
      <Setter Property="Foreground" Value="#00F0FF"/>
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="IsVisible" Value="False"/>
      <Setter Property="Margin" Value="0,0,12,0"/>
    </Style>

    <Style Selector="TextBlock.checkmark.selected">
      <Setter Property="IsVisible" Value="True"/>
    </Style>

    <Style Selector="TextBlock.checkmark.correct">
      <Setter Property="Foreground" Value="#00E676"/>
      <Setter Property="IsVisible" Value="True"/>
    </Style>
  </UserControl.Styles>

  <Border x:Name="CardBorder"
          Classes="optionCardBorder"
          PointerPressed="OnPointerPressed">
    <Grid ColumnDefinitions="Auto,*,Auto">
      <!-- Letter circle -->
      <Border Grid.Column="0"
              x:Name="LetterCircle"
              Classes="letterCircle"
              Margin="12,8,8,8">
        <TextBlock x:Name="LetterTextBlock"
                   Classes="letterText"
                   Text="{Binding #Root.Letter}"/>
      </Border>

      <!-- Option text -->
      <TextBlock Grid.Column="1"
                 x:Name="OptionTextBlock"
                 Classes="optionText"
                 Text="{Binding #Root.Text}"
                 Margin="4,12,8,12"/>

      <!-- Checkmark indicator -->
      <TextBlock Grid.Column="2"
                 x:Name="CheckmarkText"
                 Classes="checkmark"
                 Text="&#x2713;"/>
    </Grid>
  </Border>
</UserControl>
