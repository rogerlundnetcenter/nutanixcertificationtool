<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:CertStudy.Avalonia.Views"
        mc:Ignorable="d"
        x:Class="CertStudy.Avalonia.MainWindow"
        Title="🎯 CertStudy — Nutanix Exam Prep"
        MinWidth="1200"
        MinHeight="700"
        Width="1400"
        Height="900"
        WindowState="Maximized"
        Background="{StaticResource DeepSpaceBrush}">

  <Design.PreviewWith>
    <Border Background="{StaticResource DeepSpaceBrush}">
      <Grid ColumnDefinitions="280,*">
        <Border Background="{StaticResource DarkPanelBrush}" />
        <Border Grid.Column="1" Background="{StaticResource DeepSpaceBrush}" />
      </Grid>
    </Border>
  </Design.PreviewWith>

  <Grid ColumnDefinitions="280,*">
    <!-- Left Sidebar -->
    <Border Grid.Column="0"
            Background="{StaticResource DarkPanelBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,0,1,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,20,16,20" Spacing="16">

          <!-- Logo -->
          <Border Background="{StaticResource CardBgBrush}"
                  CornerRadius="8"
                  Padding="16,12"
                  HorizontalAlignment="Center">
            <TextBlock Text="CERT STUDY"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
          </Border>

          <!-- Exam Buttons -->
          <Border Background="{StaticResource CardBgBrush}"
                  CornerRadius="8"
                  Padding="12,10">
            <StackPanel Spacing="6">
              <TextBlock Text="Select Exam"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextDimBrush}" />
              <Button x:Name="BtnNCA75"
                      Content="NCA 7.5 ★"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource StatusGreenBrush}"
                      Foreground="{StaticResource DeepSpaceBrush}"
                      CornerRadius="6"
                      FontWeight="SemiBold"
                      Click="OnExamSelected" />
              <Button x:Name="BtnNCA"
                      Content="NCA 6.5"
                      HorizontalAlignment="Stretch"
                      Background="Transparent"
                      BorderBrush="{StaticResource NeonCyanBrush}"
                      BorderThickness="1"
                      Foreground="{StaticResource NeonCyanBrush}"
                      CornerRadius="6"
                      Click="OnExamSelected" />
              <Button x:Name="BtnNCM"
                      Content="NCM — MCI"
                      HorizontalAlignment="Stretch"
                      Background="Transparent"
                      BorderBrush="{StaticResource NeonPurpleBrush}"
                      BorderThickness="1"
                      Foreground="{StaticResource NeonPurpleBrush}"
                      CornerRadius="6"
                      Click="OnExamSelected" />
              <Button x:Name="BtnNCPCI"
                      Content="NCP — CI"
                      HorizontalAlignment="Stretch"
                      Background="Transparent"
                      BorderBrush="{StaticResource NeonMagentaBrush}"
                      BorderThickness="1"
                      Foreground="{StaticResource NeonMagentaBrush}"
                      CornerRadius="6"
                      Click="OnExamSelected" />
              <Button x:Name="BtnNCPAI"
                      Content="NCP — AI"
                      HorizontalAlignment="Stretch"
                      Background="Transparent"
                      BorderBrush="{StaticResource NeonCyanBrush}"
                      BorderThickness="1"
                      Foreground="{StaticResource NeonCyanBrush}"
                      CornerRadius="6"
                      Click="OnExamSelected" />
            </StackPanel>
          </Border>

          <!-- Mode Selector -->
          <Border Background="{StaticResource CardBgBrush}"
                  CornerRadius="8"
                  Padding="12,10">
            <StackPanel Spacing="6">
              <TextBlock Text="Mode"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextDimBrush}" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="BtnModeStudy"
                        Content="Study"
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource NeonPurpleBrush}"
                        Foreground="{StaticResource DeepSpaceBrush}"
                        CornerRadius="6"
                        FontWeight="SemiBold"
                        Padding="16,6"
                        Click="OnModeChanged" />
                <Button x:Name="BtnModeTest"
                        Content="Test"
                        Background="Transparent"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        Foreground="{StaticResource TextDimBrush}"
                        CornerRadius="6"
                        Padding="16,6"
                        Click="OnModeChanged" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Stats Display -->
          <Border Background="{StaticResource CardBgBrush}"
                  CornerRadius="8"
                  Padding="12,10">
            <StackPanel Spacing="8">
              <TextBlock Text="Your Stats"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextDimBrush}" />

              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Score"
                           Foreground="{StaticResource TextDimBrush}"
                           FontSize="13" />
                <TextBlock Grid.Row="0" Grid.Column="1"
                           x:Name="TxtScore"
                           Text="0/0"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Streak"
                           Foreground="{StaticResource TextDimBrush}"
                           FontSize="13" />
                <TextBlock Grid.Row="1" Grid.Column="1"
                           x:Name="TxtStreak"
                           Text="0 🔥"
                           Foreground="{StaticResource StatusAmberBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Accuracy"
                           Foreground="{StaticResource TextDimBrush}"
                           FontSize="13" />
                <TextBlock Grid.Row="2" Grid.Column="1"
                           x:Name="TxtAccuracy"
                           Text="--%"
                           Foreground="{StaticResource NeonCyanBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
              </Grid>
            </StackPanel>
          </Border>

          <!-- Action Buttons -->
          <Border Background="{StaticResource CardBgBrush}"
                  CornerRadius="8"
                  Padding="12,10">
            <StackPanel Spacing="6">
              <TextBlock Text="Actions"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextDimBrush}" />
              <Button Content="Reset"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource StatusRedBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      CornerRadius="6"
                      FontWeight="SemiBold"
                      Click="OnResetClicked" />
              <Button Content="Blueprint"
                      HorizontalAlignment="Stretch"
                      Background="Transparent"
                      BorderBrush="{StaticResource BorderSubtleBrush}"
                      BorderThickness="1"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      CornerRadius="6"
                      Click="OnBlueprintClicked" />
              <Button Content="Review"
                      HorizontalAlignment="Stretch"
                      Background="Transparent"
                      BorderBrush="{StaticResource BorderSubtleBrush}"
                      BorderThickness="1"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      CornerRadius="6"
                      Click="OnReviewClicked" />
              <Button Content="Export"
                      HorizontalAlignment="Stretch"
                      Background="Transparent"
                      BorderBrush="{StaticResource BorderSubtleBrush}"
                      BorderThickness="1"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      CornerRadius="6"
                      Click="OnExportClicked" />
              <Button Content="Lab Simulator"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource NeonPurpleBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      CornerRadius="6"
                      FontWeight="SemiBold"
                      Click="OnLabSimulatorClicked" />
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Main Content Area -->
    <Border Grid.Column="1"
            Background="{StaticResource DeepSpaceBrush}"
            x:Name="MainContentBorder">
      <ContentControl x:Name="MainContent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />
    </Border>
  </Grid>
</Window>
