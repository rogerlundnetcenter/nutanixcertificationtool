<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>app.certstudy.CertStudy</id>
  <name>CertStudy</name>
  <summary>Nutanix Certification Exam Prep</summary>
  <developer id="app.certstudy">
    <name>CertStudy Project</name>
  </developer>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      CertStudy is a cross-platform study application built with Avalonia UI
      for preparing for Nutanix certification exams.  It reads Markdown-formatted
      question banks from the Nutanix Certification Tool project and presents
      them as interactive quizzes with progress tracking, gap-fill support,
      and detailed explanations.
    </p>
    <p>Features:</p>
    <ul>
      <li>Multiple-choice and gap-fill question modes</li>
      <li>Progress tracking and score history</li>
      <li>Shuffle and category filtering</li>
      <li>Markdown-driven content — no database required</li>
      <li>Dark synthwave-inspired UI theme</li>
      <li>Self-contained exams for offline study</li>
    </ul>
  </description>

  <launchable type="desktop-id">app.certstudy.CertStudy.desktop</launchable>

  <categories>
    <category>Education</category>
    <category>Science</category>
  </categories>

  <keywords>
    <keyword>nutanix</keyword>
    <keyword>certification</keyword>
    <keyword>exam</keyword>
    <keyword>study</keyword>
    <keyword>quiz</keyword>
    <keyword>markdown</keyword>
    <keyword>nca</keyword>
    <keyword>ncp</keyword>
    <keyword>ncm</keyword>
  </keywords>

  <content_rating type="oars-1.1" />

