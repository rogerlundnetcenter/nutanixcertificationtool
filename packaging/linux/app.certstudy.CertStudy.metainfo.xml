  <url type="homepage">https://github.com/your-org/nutanixcertificationtool</url>
  <url type="bugtracker">https://github.com/your-org/nutanixcertificationtool/issues</url>
  <url type="vcs-browser">https://github.com/your-org/nutanixcertificationtool</url>

